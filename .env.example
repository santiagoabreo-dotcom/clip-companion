# Clip Companion - Configuración de Entorno (opcional)
#
# Estos valores solo precargan la ventana de setup la primera vez que
# corrés la app (después, lo que se guarda en ~/.clipcompanion.json manda).
# Sin .env, la app te los pide igual por la ventana de setup.

# Backend "cloud" (Anthropic) — obtener en console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# "cloud" o "local". Con "local" no hace falta API key, pero sí tener
# Ollama corriendo (ollama.com).
CLIP_COMPANION_PROVIDER=cloud
CLIP_COMPANION_OLLAMA_HOST=http://localhost:11434
